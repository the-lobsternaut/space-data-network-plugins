{
  "schemaVersion": 1,
  "pluginId": "exclusion-zone-tle-correlator",
  "pluginType": "correlator",
  "vendorId": "the-lobsternaut",
  "name": "Exclusion Zone TLE Correlator",
  "version": "0.1.0",
  "description": "Correlate airspace/maritime exclusion zones with TLE catalog objects using SGP4 ground track propagation and geometric intersection analysis.",
  "license": "MIT",
  "tags": ["tle", "sgp4", "exclusion-zone", "correlation", "ground-track", "launch"],
  "capabilities": { "parse": true, "convert": true, "process": true, "streaming": false },
  "ports": {
    "inputs": [
      { "name": "exclusion_zones", "description": "Exclusion zone polygons from NOTAMs/NTMs", "schema": "ExclusionZone", "required": true },
      { "name": "tle_catalog", "description": "TLE catalog entries", "schema": "TLE", "required": true }
    ],
    "outputs": [
      { "name": "correlations", "description": "Matched exclusion zones to TLE objects with confidence scores", "schema": "Correlation" }
    ]
  },
  "dependencies": {},
  "wasm": { "exportName": "TLE_CORRELATOR_WASM", "initialMemoryMB": 32, "maxMemoryMB": 256 }
}
