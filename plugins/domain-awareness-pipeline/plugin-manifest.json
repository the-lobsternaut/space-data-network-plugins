{
  "schemaVersion": 1,
  "pluginId": "domain-awareness-pipeline",
  "pluginType": "orchestrator",
  "vendorId": "the-lobsternaut",
  "name": "Domain Awareness Pipeline",
  "version": "0.1.0",
  "description": "Unified intelligence pipeline orchestrating NOTAM/NTM parsing, exclusion zone extraction, TLE correlation, ascent trajectory reconstruction, and DA-ASAT engagement zone prediction.",
  "license": "MIT",
  "tags": ["pipeline", "domain-awareness", "notam", "ntm", "tle", "asat", "orchestrator"],
  "capabilities": { "parse": true, "convert": true, "process": true, "streaming": false },
  "ports": {
    "inputs": [
      { "name": "notam_text", "description": "Raw NOTAM/TFR text", "schema": "string", "required": false },
      { "name": "ntm_text", "description": "Raw NGA maritime warning text", "schema": "string", "required": false },
      { "name": "tle_catalog", "description": "TLE catalog (3-line format)", "schema": "string", "required": false },
      { "name": "tracklet", "description": "Radar/optical tracklet observations", "schema": "Tracklet", "required": false }
    ],
    "outputs": [
      { "name": "situational_awareness", "description": "Unified SA report", "schema": "SituationalAwareness" }
    ]
  },
  "dependencies": {},
  "wasm": { "exportName": "DA_PIPELINE_WASM", "initialMemoryMB": 64, "maxMemoryMB": 512 }
}
